root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cs,csx}]
indent_style = space
indent_size = 4

[*.{csproj,props,targets,sln}]
indent_style = space
indent_size = 2

[*.cs]
# IDE0055: Fix formatting (cast spacing, etc.)
dotnet_diagnostic.IDE0055.severity = warning
csharp_space_after_cast = false
